---
const pathname = Astro.url.pathname;

const navLinks = [
  { label: "Início", href: "/" },
  { label: "Projetos", href: "/projetos" },
  { label: "Blog", href: "/blog" },
  { label: "Docs", href: "/docs" },
  { label: "Sobre", href: "/sobre" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 h-15 flex items-center bg-bg border-b border-border"
>
  <div class="container flex items-center justify-between w-full">
    <!-- Logo -->
    <a
      href="/"
      class="font-bold text-lg tracking-tight no-underline text-text font-display"
    >
      YUMA
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Navegação principal">
      {
        navLinks.map(({ label, href }) => {
          const isActive =
            href === "/" ? pathname === "/" : pathname.startsWith(href);
          return (
            <a
              href={href}
              class={isActive ? "nav-link-active" : "nav-link"}
              aria-current={isActive ? "page" : undefined}
            >
              {label}
            </a>
          );
        })
      }
    </nav>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex items-center justify-center w-9 h-9 rounded-md transition-colors text-muted"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <i class="fa-solid fa-bars text-base" aria-hidden="true"></i>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden absolute top-15 left-0 right-0 flex-col gap-1 px-6 py-4 md:hidden bg-bg border-b border-border"
    aria-label="Navegação mobile"
  >
    {
      navLinks.map(({ label, href }) => {
        const isActive =
          href === "/" ? pathname === "/" : pathname.startsWith(href);
        return (
          <a
            href={href}
            class={`block py-2 ${isActive ? "nav-link-active" : "nav-link"}`}
            aria-current={isActive ? "page" : undefined}
          >
            {label}
          </a>
        );
      })
    }
  </nav>
</header>

<!-- Spacer so content doesn't hide under fixed header -->
<div class="h-15" aria-hidden="true"></div>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.contains("flex");
    if (isOpen) {
      menu?.classList.remove("flex");
      menu?.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
    } else {
      menu?.classList.remove("hidden");
      menu?.classList.add("flex");
      toggle.setAttribute("aria-expanded", "true");
    }
  });
</script>
