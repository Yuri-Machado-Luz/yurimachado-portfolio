---
import FileTree from "@components/ui/FileTree.astro";

const { title = "Navegação", items = [] } = Astro.props;
---

<div class="flex flex-col h-full">
  <div class="pt-6 pb-2">
    <p class="sidebar-group-label" style="padding-left: 1rem; margin-top: 0;">{title}</p>
  </div>
  <div class="flex-1 overflow-y-auto px-2 pb-6">
    {items && items.length > 0 ? <FileTree items={items} /> : <slot />}
  </div>
</div>
