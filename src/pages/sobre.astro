---
import ContactForm from "@components/ui/ContactForm";
import SkillsSection from "@components/ui/SkillsSection.astro";
import { education, experience, languages } from "@data/about";
import RootLayout from "@layouts/RootLayout.astro";

const title = "Sobre | Yuri Machado Luz";
const description =
  "Desenvolvedor Full-Stack com formação em Psicologia e Sistemas de Informação. Baseado em São Paulo.";
---

<RootLayout title={title} description={description}>
  <section class="section">
    <div class="container">
      <p class="eyebrow mb-4">Sobre</p>
      <h1 class="page-title mb-4">Yuri Machado Luz</h1>
      <p class="page-lead mb-8">
        Desenvolvedor Full-Stack · Analista de Sistemas · São Paulo, Brasil
      </p>

      <div class="social-links">
        <a
          href="https://github.com/Yuri-Machado-Luz"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline"
        >
          <i class="fa-brands fa-github" aria-hidden="true"></i>
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/yurimachadoluz0311"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-outline"
        >
          <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       2. BIO
       ============================================================ -->
  <section class="container mb-20">
    <div class="bio-grid">
      <div class="bio-grid__text">
        <p>
          Comecei minha trajetória em tecnologia ainda na graduação em
          Psicologia — e desde então combino análise comportamental com
          engenharia de software. Acredito que o melhor produto nasce da
          interseção entre código robusto e design centrado em pessoas.
        </p>
        <p>
          Trabalho de forma autônoma desde 2020, desenvolvendo sistemas web,
          automações e produtos digitais para PMEs e projetos próprios. Em 2024,
          integrei a equipe da IBM onde redesenhei o ciclo de onboarding e
          reduzi o tempo de integração em 57%, antes de retomar minha trajetória
          independente.
        </p>
        <p>
          Disponível para atuar como desenvolvedor full-stack, front/back-end ou
          web developer — com foco em código limpo, testes automatizados e
          interfaces responsivas.
        </p>
      </div>

      <div class="card quick-facts">
        <p class="sidebar-group-label" style="margin-top: 0; padding-left: 0;">
          Info rápida
        </p>
        {
          [
            { icon: "fa-location-dot", text: "São Paulo, Brasil" },
            { icon: "fa-circle-check", text: "Disponível para projetos" },
            { icon: "fa-code", text: "Full-stack · Front · Back" },
            { icon: "fa-calendar", text: "Dev independente desde 2020" },
            { icon: "fa-graduation-cap", text: "ADS + Psicologia" },
          ].map((fact) => (
            <div class="fact-item">
              <i
                class={`fa-solid ${fact.icon} fact-item__icon`}
                aria-hidden="true"
              />
              <span class="fact-item__text">{fact.text}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title mb-10">Habilidades</h2>
      <SkillsSection />
    </div>
  </section>

  <section class="container mb-20">
    <h2 class="section-title mb-10">Experiência</h2>

    <div class="experience-list">
      {
        experience.map((item) => (
          <div class="experience-item">
            <div class="experience-item__timeline">
              <div class="timeline-dot" />
              <div class="timeline-line" />
            </div>

            <div class="experience-item__content">
              <h3 class="experience-item__role">{item.role}</h3>
              <div class="experience-item__meta">
                <span class="experience-item__company">{item.company}</span>
                <span class="experience-item__period">{item.period}</span>
              </div>
              <ul class="experience-item__bullets">
                {item.bullets.map((bullet) => (
                  <li class="experience-item__bullet">{bullet}</li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section class="container mb-20">
    <h2 class="section-title mb-8">Formação</h2>

    <div class="education-list">
      {
        education.map((edu) => (
          <div class="education-item">
            <p class="education-item__degree">{edu.degree}</p>
            <p class="education-item__institution">{edu.institution}</p>
            <p class="education-item__detail">{edu.detail}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="container mb-20">
    <h2 class="section-title mb-8">Idiomas</h2>

    <div class="language-grid">
      {
        languages.map((lang) => (
          <div class="language-card">
            <span class="language-card__name">{lang.name}</span>
            <span class="language-card__level">{lang.level}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section id="contato" class="section">
    <div class="container flex flex-col items-center text-center">
      <h2 class="section-title mb-8">Mensagem Direta</h2>

      <ContactForm client:load />

      <div class="social-links mt-10">
        <a
          href="https://github.com/Yuri-Machado-Luz"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
        >
          <i class="fa-brands fa-github" aria-hidden="true"></i>
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/yurimachadoluz0311"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
        >
          <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
          LinkedIn
        </a>
        <a href="mailto:yurimachadoluz@gmail.com" class="social-link">
          <i class="fa-solid fa-envelope" aria-hidden="true"></i>
          yurimachadoluz@gmail.com
        </a>
      </div>
    </div>
  </section>
</RootLayout>
