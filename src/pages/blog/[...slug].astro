---
import { getCollection, getEntry, render } from "astro:content";

import Layout from "@layouts/ArticleLayout.astro";
import { getPaginationLinks } from "../../lib/content/navigation/pagination";

export async function getStaticPaths() {
  const posts = (await getCollection(
    "blog",
    ({ data }) => !data.draft,
  )) as any[];

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { slug: post.id },
  }));
}

const slugParam = Astro.params.slug;
const slug = Array.isArray(slugParam) ? slugParam.join("/") : slugParam || "";

const post = await getEntry("blog", slug);
if (!post) {
  throw new Error(`Blog entry not found for slug: ${slug}`);
}

const rendered = await render(post);
const Content = rendered.Content;
const headings = (rendered.headings ?? []) as Array<{
  slug: string;
  text: string;
}>;

const posts = (await getCollection("blog", ({ data }) => !data.draft)) as any[];
const pagination = getPaginationLinks(slug, posts, "blog");
---

<Layout
  title={post.data.title}
  description={post.data.description}
  collection="blog"
  headings={headings}
>
  <header class="mb-8">
    <p class="eyebrow mb-3">Blog</p>
    <h1 class="page-title mb-4">
      {post.data.title}
    </h1>
    <p class="page-lead">{post.data.description}</p>
  </header>

  <hr class="my-8 border-border" />

  <article>
    <section aria-label="Conteúdo do artigo" class="prose">
      <Content />
    </section>

    {
      post.data.lastUpdated && (
        <section aria-label="Metadados do artigo" class="mt-10 pt-6 border-t border-border text-sm text-muted">
          <span>
            Atualizado em {post.data.lastUpdated.toLocaleDateString("pt-BR")}
          </span>
        </section>
      )
    }
  </article>

  {
    (pagination.prev || pagination.next) && (
      <nav
        class={[
          "mt-12 pt-6 border-t border-border flex gap-4",
          pagination.mode === "both" ? "justify-between" : pagination.mode === "prev" ? "justify-start" : "justify-end",
        ].join(" ")}
        aria-label="Navegação entre posts"
      >
        {pagination.prev && (
          <a
            class="flex flex-col gap-1 group max-w-[45%]"
            href={pagination.prev.href}
          >
            <span class="text-xs font-medium uppercase tracking-wider text-muted">Anterior</span>
            <span class="text-sm font-medium transition-colors group-hover:text-primary text-text">
              &larr; {pagination.prev.title}
            </span>
          </a>
        )}
        {pagination.next && (
          <a
            class="flex flex-col gap-1 items-end group max-w-[45%] ml-auto"
            href={pagination.next.href}
          >
            <span class="text-xs font-medium uppercase tracking-wider text-muted">Próximo</span>
            <span class="text-sm font-medium transition-colors group-hover:text-primary text-text">
              {pagination.next.title} &rarr;
            </span>
          </a>
        )}
      </nav>
    )
  }
</Layout>
