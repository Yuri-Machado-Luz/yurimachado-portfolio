---
import RootLayout from "@layouts/RootLayout.astro";
import PostCard from "@components/ui/PostCard.astro";
import { getCollection } from "astro:content";

const title = "Blog — Yuri Machado Luz";
const description =
  "Notas técnicas, process logs e reflexões sobre design e desenvolvimento de software.";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => {
    const left = a.data.lastUpdated?.getTime?.() ?? 0;
    const right = b.data.lastUpdated?.getTime?.() ?? 0;
    return right - left;
  }
);

const [featured, ...rest] = posts;
---

<RootLayout title={title} description={description}>

  <!-- ================================================================
       HERO
       ================================================================ -->
  <section class="section">
    <div class="container">
      <p class="eyebrow mb-4">Blog</p>
      <h1 class="page-title mb-6">Notas e aprendizados.</h1>
      <p class="page-lead">
        Um espaço para documentar pesquisas, decisões técnicas, reflexões sobre
        design e o que foi aprendido no caminho.
      </p>
    </div>
  </section>

  <!-- ================================================================
       POSTS
       ================================================================ -->
  <section class="container pb-20">
    {posts.length === 0 ? (
      <p class="text-sm" style="color: var(--color-muted);">
        Nenhuma publicação disponível ainda.
      </p>
    ) : (
      <div class="grid gap-5 lg:grid-cols-2">
        {featured && (
          <PostCard
            href={`/blog/${featured.id}`}
            title={featured.data.title}
            description={featured.data.description}
            date={featured.data.lastUpdated}
            featured={true}
          />
        )}
        {rest.map((post) => (
          <PostCard
            href={`/blog/${post.id}`}
            title={post.data.title}
            description={post.data.description}
            date={post.data.lastUpdated}
          />
        ))}
      </div>
    )}
  </section>

</RootLayout>
