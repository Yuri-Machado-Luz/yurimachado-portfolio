---
import { statusMap } from "@data/projects";
import RootLayout from "@layouts/RootLayout.astro";
import { getCollection } from "astro:content";

const title = "Projetos — Yuri Machado Luz";
const description =
  "Projetos reais: sites, ferramentas, bases de conhecimento e automações.";

const projects = (
  await getCollection("docs", ({ id }) => id.startsWith("projects/"))
).sort((a, b) => a.data.order - b.data.order);
---

<RootLayout title={title} description={description}>
  <section class="section">
    <div class="container">
      <p class="eyebrow mb-4">Projetos</p>
      <h1 class="page-title mb-6">Trabalhos reais.</h1>
      <p class="page-lead">
        Sites, ferramentas, bases de conhecimento e automações. Tudo aqui existe
        e pode ser verificado no GitHub.
      </p>
    </div>
  </section>

  <section class="container pb-20">
    <div class="projects-grid">
      {
        projects.map((project) => {
          const { label, badge } = statusMap[project.data.status!] ?? {
            label: project.data.status,
            badge: "badge",
          };
          return (
            <article class="project-card">
              <div class="project-card__header">
                <h2 class="project-card-title">{project.data.title}</h2>
                <span class={badge}>{label}</span>
              </div>

              <p class="project-card-desc">{project.data.description}</p>
              <div class="project-card-tags">
                {project.data.tags!.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>

              <div class="project-card__links">
                <a href={`/docs/${project.id}`} class="btn-ghost btn-sm">
                  <i class="fa-solid fa-file-lines" aria-hidden="true" />
                  Documentação
                </a>
                {project.data.github && (
                  <a
                    href={project.data.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-ghost btn-sm"
                  >
                    <i class="fa-brands fa-github" aria-hidden="true" />
                    GitHub
                  </a>
                )}
                {project.data.live && (
                  <a
                    href={project.data.live}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="btn-outline btn-sm"
                  >
                    <i
                      class="fa-solid fa-arrow-up-right-from-square"
                      aria-hidden="true"
                    />
                    Ver site
                  </a>
                )}
              </div>
            </article>
          );
        })
      }
    </div>
  </section>
</RootLayout>
