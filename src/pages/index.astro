---
import { heroStats } from "@data/about";
import { statusMap } from "@data/projects";
import RootLayout from "@layouts/RootLayout.astro";
import { getCollection } from "astro:content";

const title = "Yuri Machado Luz — Desenvolvedor Full-Stack";
const description = `Full-Stack Developer focado em arquitetura, automação e design de sistemas.
  Desenho, documento e implemento aplicações web, automações e pipelines — estruturando fluxoes e reduzindo operações manuais com soluções sustentáveis e escaláveis.`;

const allPosts = await getCollection("notas");
const recentPosts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const dateA = a.data.lastUpdated
      ? new Date(a.data.lastUpdated).getTime()
      : 0;
    const dateB = b.data.lastUpdated
      ? new Date(b.data.lastUpdated).getTime()
      : 0;
    return dateB - dateA;
  })
  .slice(0, 3);

const featuredProjects = (
  await getCollection(
    "docs",
    ({ id, data }) => id.startsWith("projects/") && !data.draft,
  )
)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<RootLayout title={title} description={description}>
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <p class="badge-primary mb-8 text-sm">
      <span class="px-1 animate-pulse text-xl">•</span>Aberto para oportunidades
    </p>
    <div class="hero__content">
      <h1 class="page-title">Yuri Machado</h1>
      <p class="eyecatch mt-8 mb-6 uppercase">Full-Stack Developer</p>
      <p class="page-lead">
        Sou Analista de Sistemas com experiência em desenvolvimento Full-Stack,
        APIs REST, UI/UX e automação de processos. Especializado em processos
        multidisciplinares com foco em arquitetura, documentação e
        escalabilidade.
      </p>
      <div class="hero__cta mt-10">
        <a href="/projetos" class="btn-primary btn-lg">Ver Projetos</a>
        <a href="/sobre" class="btn-outline btn-lg">Saiba mais</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-grid__text">
          <h2 class="section-title">Sobre mim</h2>
          <p class="page-lead">
            <p class="text-justify">
              Desenvolvedor com formação multidisciplinar — iniciado em
              Psicologia, especializando-me em Análise e Desenvolvimento de
              Sistemas. Essa mistura me deu um olhar atento à estrutura,
              comportamento e clareza, que aplico ao projetar sistemas web,
              automações e processos bem documentados.
            </p>
            <p class="text-justify">
              Desde 2020, atuo de forma autônoma. Crio aplicações escaláveis,
              fluxos automatizados e re-designs de processos — sempre
              estruturando operações para que as soluções sejam compreensíveis e
              escaláveis.
            </p>
            <p class="text-justify">
              Escrevo, desenho e documento o que construo. Atuo também como
              designer gráfico, redator técnico e ghostwriter. Isso me permite
              cobrir um projeto inteiro: da arquitetura à comunicação final, com
              rigor e sigilo.
            </p>
          </p>
          <a href="/sobre" class="btn-ghost self-start"
            >Conheça minha trajetória →</a
          >
        </div>

        <div class="about-grid__stats">
          {
            heroStats.map((stat) => (
              <div class="stat-item">
                <span class="stat-item__value">{stat.value}</span>
                <span class="stat-item__label">{stat.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow mb-3">Projetos</p>
      <h2 class="section-title mb-10">Trabalhos selecionados</h2>

      <div class="featured-grid">
        {
          featuredProjects.map((project) => {
            const status = statusMap[project.data.status ?? ""] ?? {
              label: project.data.status ?? "",
              badge: "badge",
            };
            return (
              <a href={`/docs/${project.id}`} class="project-card no-underline">
                <div class="project-card__header">
                  <h3 class="project-card-title">{project.data.title}</h3>
                  <span class={status.badge}>{status.label}</span>
                </div>
                <p class="project-card-desc">{project.data.description}</p>
                <div class="project-card-tags">
                  {(project.data.tags ?? []).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </a>
            );
          })
        }
      </div>

      <div class="mt-10">
        <a href="/projetos" class="btn-ghost">Ver todos os projetos →</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow mb-3">Notas</p>
      <h2 class="section-title mb-10">Publicações recentes</h2>

      {
        recentPosts.length > 0 ? (
          <div>
            {recentPosts.map((post) => (
              <a href={`/notas/${post.id}`} class="post-item no-underline">
                <span class="post-item-title">{post.data.title}</span>
                <span class="post-item-meta">
                  {post.data.description}
                  {post.data.lastUpdated && (
                    <>
                      {" "}
                      &mdash;{" "}
                      {new Date(post.data.lastUpdated).toLocaleDateString(
                        "pt-BR",
                        { year: "numeric", month: "long", day: "numeric" },
                      )}
                    </>
                  )}
                </span>
              </a>
            ))}
          </div>
        ) : (
          <p class="post-item-meta">Nenhuma publicação disponível ainda.</p>
        )
      }
      <a href="/artigos" class="btn-ghost pl-0">Ver todas as notas</a>
    </div>
  </section>

  <section class="section mt-0 pt-0">
    <div class="container contact-cta">
      <h2 class="section-title">Vamos conversar?</h2>

      <a href="/sobre#contato" class="btn-primary">Entrar em contato</a>

      <div class="social-links mt-2">
        <a
          href="https://github.com/Yuri-Machado-Luz"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
        >
          <i class="fa-brands fa-github" aria-hidden="true"></i>
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/yurimachadoluz"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
        >
          <i class="fa-brands fa-linkedin" aria-hidden="true"></i>
          LinkedIn
        </a>
        <a href="mailto:yurimachadoluz@gmail.com" class="social-link">
          <i class="fa-solid fa-envelope" aria-hidden="true"></i>
          Email
        </a>
      </div>
    </div>
  </section>
</RootLayout>
